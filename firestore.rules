rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Block everything by default — only Cloud Functions (Admin SDK) can write
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can read their own profile (written by Functions only)
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Users can read and write their own plan
    match /plans/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
