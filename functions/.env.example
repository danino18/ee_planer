# Copy this file to .env (NOT committed to git)
# Set these values in your local environment or via Firebase Secret Manager

# Comma-separated list of Firebase UIDs that have admin access
ADMIN_UIDS=uid1,uid2

# Comma-separated list of allowed browser origins for the Functions API
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.example

# AI provider keys - set via Firebase Secrets in production:
#   firebase functions:secrets:set OPENAI_API_KEY
#   firebase functions:secrets:set ANTHROPIC_API_KEY
OPENAI_API_KEY=replace-with-real-openai-key
ANTHROPIC_API_KEY=replace-with-real-anthropic-key
