rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow read: if isSignedInOwner(uid);
      allow write: if false;
    }

    match /plans/{uid} {
      allow read, write: if isSignedInOwner(uid);
    }

    // Writes still go exclusively through Cloud Functions (Admin SDK) so
    // server-side validation, sanitization and audit can happen.
    // Reads are allowed directly so clients can use onSnapshot for real-time
    // collaboration. The conditions mirror the GET /shares/:id Cloud Function.
    match /shares/{shareId} {
      allow read: if (
        !resource.data.revoked
        && (resource.data.expiresAt == null || request.time.toMillis() < resource.data.expiresAt)
        && (
          (request.auth != null && request.auth.uid == resource.data.ownerUid)
          || resource.data.access == 'public'
          || (
            resource.data.access == 'restricted'
            && request.auth != null
            && request.auth.token.email is string
            && (request.auth.token.email.lower() in resource.data.allowedEmails)
          )
        )
      );
      allow write: if false;
    }
  }
}
