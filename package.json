{
  "name": "technion-ee-planner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync:general-requirements": "node scripts/sync-general-requirements.mjs",
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "npm run sync:general-requirements && npm run typecheck && vite build",
    "lint": "eslint .",
    "test": "node scripts/run-tests.mjs",
    "build:functions": "npm --prefix functions run build",
    "lint:functions": "npm --prefix functions run lint",
    "analyze:bundle": "node scripts/check-bundle-budget.mjs",
    "perf:bundle": "npm run build && npm run analyze:bundle",
    "check": "npm run lint && npm run test && npm run build && npm run analyze:bundle && npm run build:functions && npm run lint:functions",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "firebase": "^12.10.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
