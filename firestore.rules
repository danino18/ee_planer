rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow read: if isSignedInOwner(uid);
      allow write: if false;
    }

    match /plans/{uid} {
      allow read, write: if isSignedInOwner(uid);
    }
  }
}
